# Sao chép file này thành backend/.env và điền giá trị thật.
# Trên Render: set các biến này trong Dashboard > Environment.
# Hướng dẫn chi tiết: backend/docs/SUPABASE_SETUP.md

# --- Supabase (multi-user) ---
# Connection string Postgres (Session/Transaction pooler). BỎ TRỐNG để dùng SQLite local.
DATABASE_URL=postgresql+psycopg2://postgres.xxxx:PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres?sslmode=require
# Legacy JWT secret (Settings > API > JWT) — backend verify token của Supabase.
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
# Khóa mã hóa credential nhà cung cấp (Fernet.generate_key()).
FERNET_KEY=your-fernet-key
# Email được cấp quyền admin (CSV). Token có email này => is_admin.
ADMIN_EMAILS=vuhp@allexceed.co.jp
# Đặt =1 để TẮT auth khi test local (KHÔNG dùng trên production).
AUTH_DISABLED=0

# --- Tuya Cloud (cửa cuốn + máy cho ăn Rojeco dùng chung 1 project) ---
TUYA_ACCESS_ID=your-tuya-access-id
TUYA_ACCESS_KEY=your-tuya-access-key
TUYA_API_ENDPOINT=https://openapi-sg.iotbing.com/
# Schema app đã liên kết trong Tuya IoT (dùng để discover thiết bị user). Tùy chọn.
TUYA_APP_SCHEMA=

# --- OpenRouter (AI parse lệnh giọng nói) ---
OPENROUTER_API_KEY=your-openrouter-key

# --- VeSync ---
# KHÔNG còn credential dùng chung — mỗi user tự nhập email/pass trong app,
# backend mã hóa & lưu ở bảng vendor_accounts. (Các biến cũ VESYNC_* không còn dùng.)
